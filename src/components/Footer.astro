---
import profile from "../data/profile.json";

const base = import.meta.env.BASE_URL.replace(/\/$/, "");
const year = new Date().getFullYear();
---

<footer
  class="mt-24 border-t border-[var(--color-line)] bg-[var(--color-surface)]"
>
  <div class="mx-auto grid max-w-6xl gap-10 px-5 py-14 sm:px-8 md:grid-cols-3">
    <div>
      <a href={`${base}/`} class="text-xl font-bold text-[var(--color-fg)]"
        >{profile.name}</a
      >
      <p class="mt-2 text-sm text-[var(--color-muted)]">
        {profile.role}
      </p>
      <p class="mt-4 max-w-sm text-sm text-[var(--color-muted)]">
        讓品牌在對的時刻、被對的人看見。
      </p>
    </div>

    <div>
      <span class="eyebrow">Sitemap</span>
      <ul class="mt-4 space-y-2 text-sm">
        <li><a class="nav-link" href={`${base}/`}>簡歷</a></li>
        <li><a class="nav-link" href={`${base}/works`}>作品集</a></li>
      </ul>
    </div>

    <div>
      <span class="eyebrow">Contact</span>
      <ul class="mt-4 space-y-2 text-sm">
        <li>
          <a class="nav-link" href={`mailto:${profile.email}`}>{profile.email}</a>
        </li>
        <li>
          <a class="nav-link" href={`tel:+886${profile.phone.replace(/\D/g,"").slice(1)}`}>{profile.phone}</a>
        </li>
      </ul>
    </div>
  </div>

  <div
    class="border-t border-[var(--color-line)] px-5 py-5 text-center text-xs text-[var(--color-subtle)] sm:px-8"
  >
    © {year} {profile.name}. All rights reserved.
  </div>
</footer>

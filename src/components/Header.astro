---
import profile from "../data/profile.json";

const base = import.meta.env.BASE_URL.replace(/\/$/, "");
const path = Astro.url.pathname.replace(/\/$/, "") || "/";

const tabs = [
  { href: "/", label: "簡歷" },
  { href: "/works", label: "作品集" },
];

function isActive(href: string) {
  const target = href === "/" ? base || "/" : `${base}${href}`;
  if (href === "/") {
    return path === "/" || path === base || path === "";
  }
  return path === target || path.startsWith(`${target}/`);
}
---

<header
  class="sticky top-0 z-40 border-b border-[var(--color-line)] backdrop-blur"
  style="background: color-mix(in srgb, var(--color-bg) 80%, transparent);"
>
  <nav
    class="mx-auto flex max-w-6xl items-center justify-between gap-4 px-5 py-4 sm:px-8"
  >
    <a
      href={`${base}/`}
      class="flex items-center gap-2 font-bold tracking-tight"
      aria-label="返回簡歷"
    >
      <span
        class="inline-block h-2.5 w-2.5 rounded-full"
        style="background: var(--color-accent);"
        aria-hidden="true"></span>
      <span class="text-[var(--color-fg)]">{profile.name}</span>
      <span class="hidden text-xs text-[var(--color-muted)] sm:inline"
        >／ {profile.role}</span
      >
    </a>

    <div
      class="inline-flex items-center gap-1 rounded-full border border-[var(--color-line)] bg-[var(--color-surface)] p-1"
      role="tablist"
      aria-label="頁面切換"
    >
      {
        tabs.map((tab) => {
          const active = isActive(tab.href);
          return (
            <a
              href={`${base}${tab.href}`}
              role="tab"
              aria-selected={active}
              class:list={[
                "rounded-full px-4 py-1.5 text-sm font-medium transition-colors",
                active
                  ? "bg-[var(--color-accent)] text-black"
                  : "text-[var(--color-muted)] hover:text-[var(--color-fg)]",
              ]}
            >
              {tab.label}
            </a>
          );
        })
      }
    </div>
  </nav>
</header>

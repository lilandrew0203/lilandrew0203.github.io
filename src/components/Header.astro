---
import profile from "../data/profile.json";

const base = import.meta.env.BASE_URL.replace(/\/$/, "");
const path = Astro.url.pathname.replace(/\/$/, "") || "/";

const nav = [
  { href: "/", label: "首頁" },
  { href: "/works", label: "作品集" },
  { href: "/about", label: "關於" },
  { href: "/contact", label: "聯絡" },
];

function isActive(href: string) {
  if (href === "/") return path === "/" || path === base;
  return path === `${base}${href}` || path.startsWith(`${base}${href}/`);
}
---

<header
  class="sticky top-0 z-40 border-b border-[var(--color-line)] backdrop-blur"
  style="background: color-mix(in srgb, var(--color-bg) 80%, transparent);"
>
  <nav
    class="mx-auto flex max-w-6xl items-center justify-between px-5 py-4 sm:px-8"
  >
    <a
      href={`${base}/`}
      class="flex items-center gap-2 font-bold tracking-tight"
      aria-label="返回首頁"
    >
      <span
        class="inline-block h-2.5 w-2.5 rounded-full"
        style="background: var(--color-accent);"
        aria-hidden="true"></span>
      <span class="text-[var(--color-fg)]">{profile.name}</span>
      <span class="hidden text-xs text-[var(--color-muted)] sm:inline"
        >／ {profile.role}</span
      >
    </a>

    <button
      type="button"
      id="menu-toggle"
      class="md:hidden inline-flex h-9 w-9 items-center justify-center rounded-full border border-[var(--color-line)] text-[var(--color-fg)]"
      aria-controls="primary-nav"
      aria-expanded="false"
      aria-label="開啟選單"
    >
      <svg
        width="18"
        height="18"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
        ><line x1="3" y1="6" x2="21" y2="6"></line><line
          x1="3"
          y1="12"
          x2="21"
          y2="12"></line><line x1="3" y1="18" x2="21" y2="18"></line></svg
      >
    </button>

    <ul
      id="primary-nav"
      class="hidden items-center gap-7 md:flex"
    >
      {
        nav.map((item) => (
          <li>
            <a
              href={`${base}${item.href}`}
              class="nav-link"
              aria-current={isActive(item.href) ? "page" : undefined}
            >
              {item.label}
            </a>
          </li>
        ))
      }
      <li>
        <a href={`${base}/contact`} class="btn btn-primary text-sm">
          合作邀約 →
        </a>
      </li>
    </ul>
  </nav>

  <div
    id="mobile-nav"
    class="md:hidden hidden border-t border-[var(--color-line)] px-5 py-4"
  >
    <ul class="flex flex-col gap-3">
      {
        nav.map((item) => (
          <li>
            <a
              href={`${base}${item.href}`}
              class="nav-link block"
              aria-current={isActive(item.href) ? "page" : undefined}
            >
              {item.label}
            </a>
          </li>
        ))
      }
      <li>
        <a href={`${base}/contact`} class="btn btn-primary w-full justify-center text-sm">
          合作邀約 →
        </a>
      </li>
    </ul>
  </div>
</header>

<script is:inline>
  const btn = document.getElementById("menu-toggle");
  const panel = document.getElementById("mobile-nav");
  if (btn && panel) {
    btn.addEventListener("click", () => {
      const open = panel.classList.toggle("hidden") === false;
      btn.setAttribute("aria-expanded", open ? "true" : "false");
    });
  }
</script>

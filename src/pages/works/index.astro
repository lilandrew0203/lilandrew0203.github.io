---
import BaseLayout from "../../layouts/BaseLayout.astro";
import WorkCard from "../../components/WorkCard.astro";
import { getCollection } from "astro:content";

const works = await getCollection("works");
const workMap = new Map(works.map((w) => [w.id, w]));

const YOUTUBE_PLAYLIST =
  "https://youtube.com/playlist?list=PLgP7ZYIxsAP8LRLj_jmnvUW2dgb5v2qId";

const sections = [
  {
    id: "billboard",
    title: "看板發想",
    slugs: [
      "billboard-5080",
      "billboard-ghost-month",
      "billboard-goddess",
      "billboard-april-fools",
      "single-dogs-food",
    ],
    youtubeUrl: null,
  },
  {
    id: "influencer",
    title: "業配合作",
    slugs: ["influencer-collab", "youtube-collab"],
    youtubeUrl: YOUTUBE_PLAYLIST,
  },
  {
    id: "social",
    title: "社群經營",
    slugs: [
      "cosmic-contest",
      "social-trending",
      "social-store-stories",
      "social-fake-recruitment",
    ],
    youtubeUrl: null,
  },
  {
    id: "event",
    title: "實體活動",
    slugs: ["event-marketing"],
    youtubeUrl: null,
  },
  {
    id: "others",
    title: "其他",
    slugs: [],
    youtubeUrl: null,
  },
] as const;
---

<BaseLayout title="作品集 | 陳彥竹">
  <section class="mx-auto max-w-6xl px-5 pt-16 pb-12 sm:px-8 sm:pt-24">
    <span class="eyebrow">Selected works</span>
    <h1 class="h-display mt-4">代表作品集</h1>
    <p class="mt-6 max-w-2xl text-[var(--color-muted)]">
      點開任一案例可以看到完整背景、執行策略、KPI 數字、圖片與媒體連結。
    </p>
  </section>

  <div class="mx-auto max-w-6xl space-y-20 px-5 pb-24 sm:px-8">
    {
      sections.map((section) => {
        const sectionWorks = section.slugs
          .map((slug) => workMap.get(slug))
          .filter(Boolean);

        return (
          <section>
            <div class="mb-8 flex flex-wrap items-center justify-between gap-4 border-b border-[var(--color-line)] pb-4">
              <h2 class="text-2xl font-bold text-[var(--color-fg)]">
                <span style="color: var(--color-accent);">▍</span>
                {section.title}
              </h2>
              {section.youtubeUrl && (
                <a
                  href={section.youtubeUrl}
                  target="_blank"
                  rel="noreferrer"
                  class="inline-flex items-center gap-2 rounded-full border px-4 py-2 text-sm transition-colors hover:border-[var(--color-accent)] hover:text-[var(--color-accent)]" style="border-color: var(--color-accent); color: var(--color-accent);"
                >
                  <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor">
                    <path d="M23.5 6.2a3 3 0 0 0-2.1-2.1C19.5 3.6 12 3.6 12 3.6s-7.5 0-9.4.5A3 3 0 0 0 .5 6.2 31.3 31.3 0 0 0 0 12a31.3 31.3 0 0 0 .5 5.8 3 3 0 0 0 2.1 2.1c1.9.5 9.4.5 9.4.5s7.5 0 9.4-.5a3 3 0 0 0 2.1-2.1A31.3 31.3 0 0 0 24 12a31.3 31.3 0 0 0-.5-5.8zM9.7 15.6V8.4l6.3 3.6-6.3 3.6z" />
                  </svg>
                  其他合作案例 →
                </a>
              )}
            </div>

            {sectionWorks.length > 0 ? (
              <div class="flex snap-x snap-mandatory gap-5 overflow-x-auto pb-3 md:grid md:grid-cols-2 md:overflow-x-visible lg:grid-cols-3">
                {sectionWorks.map(
                  (w) =>
                    w && (
                      <div class="w-[80vw] shrink-0 snap-start md:w-auto">
                        <WorkCard entry={w} />
                      </div>
                    )
                )}
              </div>
            ) : (
              <p class="text-sm text-[var(--color-subtle)]">暫無案例，持續更新中。</p>
            )}
          </section>
        );
      })
    }
  </div>
</BaseLayout>

---
import BaseLayout from "../../layouts/BaseLayout.astro";
import KpiCard from "../../components/KpiCard.astro";
import { getCollection, render } from "astro:content";
import type { GetStaticPaths } from "astro";

export const getStaticPaths = (async () => {
  const works = await getCollection("works");
  return works.map((entry) => ({
    params: { slug: entry.id.replace(/\.md$/, "") },
    props: { entry },
  }));
}) satisfies GetStaticPaths;

const { entry } = Astro.props;
const { Content } = await render(entry);
const data = entry.data;
const base = import.meta.env.BASE_URL.replace(/\/$/, "");

// Bento KPI layout — first KPI larger, then asymmetric grid
const kpis = data.kpis;
---

<BaseLayout title={`${data.title} | 陳彥竹`} description={data.summary}>
  <!-- ============ HEADER ============ -->
  <section class="mx-auto max-w-6xl px-5 pt-12 sm:px-8 sm:pt-20">
    <a
      href={`${base}/works`}
      class="inline-flex items-center gap-2 text-sm text-[var(--color-muted)] hover:text-[var(--color-accent)]"
    >
      ← 回作品列表
    </a>

    <div class="mt-6 flex flex-wrap items-center gap-2">
      {data.category.map((c) => <span class="chip">{c}</span>)}
    </div>

    <h1 class="h-display mt-6">{data.title}</h1>

    <div
      class="mt-8 grid gap-6 border-t border-[var(--color-line)] pt-8 md:grid-cols-4"
    >
      <div>
        <div class="text-[10px] uppercase tracking-[0.3em] text-[var(--color-subtle)]">
          客戶
        </div>
        <div class="mt-2 font-medium">{data.client}</div>
      </div>
      <div>
        <div class="text-[10px] uppercase tracking-[0.3em] text-[var(--color-subtle)]">
          執行時間
        </div>
        <div class="mt-2 font-medium">{data.period}</div>
      </div>
      <div>
        <div class="text-[10px] uppercase tracking-[0.3em] text-[var(--color-subtle)]">
          我的角色
        </div>
        <div class="mt-2 font-medium">{data.role}</div>
      </div>
      {
        data.partners.length > 0 && (
          <div>
            <div class="text-[10px] uppercase tracking-[0.3em] text-[var(--color-subtle)]">
              合作夥伴
            </div>
            <div class="mt-2 font-medium">{data.partners.join("、")}</div>
          </div>
        )
      }
    </div>
  </section>

  <!-- ============ COVER ============ -->
  <section class="mx-auto mt-12 max-w-6xl px-5 sm:px-8">
    <div
      class="relative overflow-hidden rounded-3xl border border-[var(--color-line)] bg-[var(--color-surface)]"
      style="aspect-ratio: 16 / 9;"
    >
      {
        data.coverImage ? (
          <img
            src={data.coverImage}
            alt={`${data.title} cover`}
            class="h-full w-full object-cover"
          />
        ) : (
          <div
            class="flex h-full w-full items-center justify-center text-sm tracking-[0.4em] text-[var(--color-subtle)]"
          >
            COVER IMAGE — {data.client.toUpperCase()}
          </div>
        )
      }
    </div>
  </section>

  <!-- ============ KPI BENTO ============ -->
  {
    kpis.length > 0 && (
      <section class="mx-auto max-w-6xl px-5 py-20 sm:px-8">
        <span class="eyebrow">KPI 成果</span>
        <h2 class="h-section mt-3">這個案子留下了什麼數字</h2>

        <div class="mt-10 bento">
          {kpis.map((k, i) => {
            const span = i === 0 ? "b-1 md:col-span-3" : i === 1 ? "b-2" : "b-2";
            return (
              <div class={span}>
                <KpiCard
                  label={k.label}
                  value={k.value}
                  growth={k.growth}
                  emphasis={i === 0}
                />
              </div>
            );
          })}
        </div>
      </section>
    )
  }

  <!-- ============ BODY (markdown) ============ -->
  <section class="mx-auto max-w-3xl px-5 py-12 sm:px-8">
    <article
      class="prose prose-invert"
      style="--tw-prose-body: var(--color-fg);"
    >
      <Content />
    </article>
  </section>


  <!-- ============ MEDIA ============ -->
  {
    data.media.length > 0 && (
      <section class="mx-auto max-w-6xl px-5 py-12 sm:px-8">
        <span class="eyebrow">Media</span>
        <h3 class="h-section mt-3">圖片與影片</h3>
        <div class="mt-8 grid gap-6 md:grid-cols-2">
          {data.media.map((m) =>
            m.type === "youtube" ? (
              <figure>
                <div
                  class="overflow-hidden rounded-2xl border border-[var(--color-line)] bg-black"
                  style="aspect-ratio: 16 / 9;"
                >
                  <iframe
                    src={m.src}
                    class="h-full w-full"
                    loading="lazy"
                    allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
                    allowfullscreen
                    title={m.caption ?? "video"}
                  />
                </div>
                {m.caption && (
                  <figcaption class="mt-3 text-sm text-[var(--color-muted)]">
                    {m.caption}
                  </figcaption>
                )}
              </figure>
            ) : (
              <figure>
                <img
                  src={m.src}
                  alt={m.caption ?? ""}
                  class="w-full rounded-2xl border border-[var(--color-line)]"
                />
                {m.caption && (
                  <figcaption class="mt-3 text-sm text-[var(--color-muted)]">
                    {m.caption}
                  </figcaption>
                )}
              </figure>
            ),
          )}
        </div>
      </section>
    )
  }

  <div class="pb-16"></div>

  <script>
    import "../../scripts/countup.ts";
  </script>
</BaseLayout>

<style is:global>
  .prose {
    color: var(--color-fg);
    font-size: 1.05rem;
    line-height: 1.8;
  }
  .prose h2 {
    font-family: var(--font-tc);
    font-weight: 700;
    font-size: clamp(1.4rem, 2.5vw, 1.8rem);
    margin-top: 2.5rem;
    margin-bottom: 1rem;
    color: var(--color-fg);
  }
  .prose h3 {
    font-family: var(--font-tc);
    font-weight: 700;
    font-size: 1.15rem;
    margin-top: 2rem;
    margin-bottom: 0.6rem;
    color: var(--color-fg);
  }
  .prose p {
    margin-top: 1rem;
    margin-bottom: 1rem;
    color: var(--color-fg);
  }
  .prose ul {
    list-style: none;
    padding-left: 0;
    margin: 1rem 0;
  }
  .prose ul li {
    position: relative;
    padding-left: 1.25rem;
    margin: 0.5rem 0;
    color: var(--color-fg);
  }
  .prose ul li::before {
    content: "";
    position: absolute;
    left: 0;
    top: 0.75em;
    width: 0.5rem;
    height: 1px;
    background: var(--color-accent);
  }
  .prose strong {
    color: var(--color-accent);
    font-weight: 700;
  }
  .prose blockquote {
    border-left: 2px solid var(--color-accent);
    padding-left: 1.25rem;
    color: var(--color-muted);
    font-style: italic;
    margin: 2rem 0;
  }
  .prose a {
    color: var(--color-accent);
    text-decoration: underline;
    text-underline-offset: 4px;
  }
</style>

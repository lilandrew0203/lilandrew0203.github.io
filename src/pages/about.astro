---
import BaseLayout from "../layouts/BaseLayout.astro";
import profile from "../data/profile.json";
import experience from "../data/experience.json";
import skills from "../data/skills.json";

const base = import.meta.env.BASE_URL.replace(/\/$/, "");
---

<BaseLayout title={`關於 ${profile.name} | ${profile.role}`}>
  <!-- ============ INTRO ============ -->
  <section class="mx-auto max-w-6xl px-5 pt-16 pb-12 sm:px-8 sm:pt-24">
    <span class="eyebrow">About</span>
    <h1 class="h-display mt-4">我是 {profile.name}。</h1>
    <p
      class="mt-8 max-w-3xl text-base leading-relaxed text-[var(--color-muted)] sm:text-lg"
    >
      行銷企劃出身，過去四年專注在「議題行銷」與「品牌成長」之間找平衡。喜歡把品牌幽默感、消費者情緒缺口、數據驗證三件事疊在一起做。相信好的行銷不是「讓人記住」，而是「讓人願意分享」。
    </p>

    <div class="mt-10 flex flex-wrap gap-3">
      <a href={`${base}/contact`} class="btn btn-primary">寫信給我 →</a>
      {
        profile.social.map((s) => (
          <a
            href={s.url}
            target="_blank"
            rel="noreferrer"
            class="btn btn-ghost"
          >
            {s.label}
          </a>
        ))
      }
    </div>
  </section>

  <!-- ============ TIMELINE ============ -->
  <section class="mx-auto max-w-6xl px-5 py-16 sm:px-8">
    <span class="eyebrow">Experience</span>
    <h2 class="h-section mt-3">工作經歷</h2>

    <ol class="mt-10 relative border-l border-[var(--color-line)] pl-6">
      {
        experience.map((e) => (
          <li class="reveal relative pb-10 last:pb-0">
            <span
              class="absolute -left-[34px] top-1 h-3 w-3 rounded-full ring-4 ring-[var(--color-bg)]"
              style={`background: ${e.current ? "var(--color-accent)" : "var(--color-line)"};`}
            />
            <div class="flex flex-wrap items-baseline gap-x-3 gap-y-1">
              <h3 class="text-lg font-semibold text-[var(--color-fg)]">
                {e.title}
              </h3>
              <span class="text-sm text-[var(--color-muted)]">@ {e.company}</span>
              <span class="text-xs text-[var(--color-subtle)]">
                {e.period}
              </span>
            </div>
            <ul class="mt-3 space-y-1.5 text-sm text-[var(--color-muted)]">
              {e.highlights.map((h) => (
                <li class="flex gap-2">
                  <span
                    class="mt-2 inline-block h-px w-2 flex-shrink-0"
                    style="background: var(--color-accent);"
                  />
                  <span>{h}</span>
                </li>
              ))}
            </ul>
          </li>
        ))
      }
    </ol>
  </section>

  <!-- ============ SKILLS ============ -->
  <section class="mx-auto max-w-6xl px-5 py-16 sm:px-8">
    <span class="eyebrow">Skills</span>
    <h2 class="h-section mt-3">技能</h2>

    <div class="mt-10 grid gap-6 md:grid-cols-2">
      {
        skills.map((group) => (
          <div class="reveal rounded-2xl border border-[var(--color-line)] bg-[var(--color-surface)] p-6">
            <h3 class="text-base font-semibold text-[var(--color-fg)]">
              {group.group}
            </h3>
            <div class="mt-4 flex flex-wrap gap-2">
              {group.items.map((item) => (
                <span class="chip">{item}</span>
              ))}
            </div>
          </div>
        ))
      }
    </div>
  </section>
</BaseLayout>

---
import BaseLayout from "../layouts/BaseLayout.astro";
import profile from "../data/profile.json";
import experience from "../data/experience.json";
import skills from "../data/skills.json";

const languageGroup = skills.find((g) => g.group.startsWith("語言"));
const mainJob = experience[0];
const subsections = (mainJob.subsections ?? []) as {
  title: string;
  bullets: string[];
}[];
---

<BaseLayout>
  <!-- ============ HERO ============ -->
  <section
    class="relative mx-auto max-w-6xl px-5 pt-16 pb-20 sm:px-8 sm:pt-24 sm:pb-24"
  >
    <div
      class="pointer-events-none absolute -top-32 right-0 h-[420px] w-[420px] rounded-full opacity-30 blur-3xl"
      style="background: radial-gradient(closest-side, var(--color-accent), transparent);"
    >
    </div>

    <span class="eyebrow fade-up fade-up-1">{profile.role}</span>

    <h1 class="h-display mt-6 fade-up fade-up-2">
      嗨, 我是<span style="color: var(--color-accent);">{profile.name}</span>。<br
      />
      <span class="text-[var(--color-muted)]">把品牌講進對的人耳裡。</span>
    </h1>

    <p
      class="mt-8 max-w-2xl text-base leading-relaxed text-[var(--color-muted)] sm:text-lg fade-up fade-up-3"
    >
      {profile.tagline}
    </p>

    <div class="mt-16 grid grid-cols-2 gap-4 fade-up fade-up-4 sm:grid-cols-4 sm:gap-6">
      {
        profile.stats.map((s) => (
          <div class="rounded-2xl border border-[var(--color-line)] bg-[var(--color-surface)] p-4 sm:p-6">
            <div class="text-[10px] uppercase tracking-[0.3em] text-[var(--color-subtle)]">
              {s.label}
            </div>
            <div
              class="mt-2 font-bold leading-none"
              style="font-size: clamp(1.75rem, 4vw, 2.75rem);"
            >
              <span data-countup={s.value} style="color: var(--color-accent);">
                {s.value}
              </span>
              {s.suffix && (
                <span class="ml-1 text-sm text-[var(--color-muted)]">
                  {s.suffix}
                </span>
              )}
            </div>
          </div>
        ))
      }
    </div>
  </section>

  <!-- ============ 個人資料 ============ -->
  <section class="mx-auto max-w-6xl px-5 py-12 sm:px-8">
    <span class="eyebrow">Profile</span>
    <h2 class="h-section mt-3">個人資料</h2>

    <dl
      class="mt-8 grid gap-y-4 gap-x-10 text-sm sm:grid-cols-2 lg:grid-cols-3"
    >
      <div class="flex gap-3">
        <dt class="w-20 shrink-0 text-[var(--color-subtle)]">姓名</dt>
        <dd class="text-[var(--color-fg)]">{profile.name}</dd>
      </div>
      <div class="flex gap-3">
        <dt class="w-20 shrink-0 text-[var(--color-subtle)]">職稱</dt>
        <dd class="text-[var(--color-fg)]">{profile.role}</dd>
      </div>
      <div class="flex gap-3">
        <dt class="w-20 shrink-0 text-[var(--color-subtle)]">行銷年資</dt>
        <dd class="text-[var(--color-fg)]">{profile.yearsOfExperience} 年</dd>
      </div>
      <div class="flex gap-3">
        <dt class="w-20 shrink-0 text-[var(--color-subtle)]">Email</dt>
        <dd>
          <a
            class="text-[var(--color-fg)] hover:text-[var(--color-accent)]"
            href={`mailto:${profile.email}`}>{profile.email}</a
          >
        </dd>
      </div>
      <div class="flex gap-3">
        <dt class="w-20 shrink-0 text-[var(--color-subtle)]">電話</dt>
        <dd>
          <a
            class="text-[var(--color-fg)] hover:text-[var(--color-accent)]"
            href={`tel:+886${profile.phone.replace(/\D/g, "").slice(1)}`}
            >{profile.phone}</a
          >
        </dd>
      </div>
      <div class="flex gap-3">
        <dt class="w-20 shrink-0 text-[var(--color-subtle)]">城市</dt>
        <dd class="text-[var(--color-fg)]">{profile.location}</dd>
      </div>
    </dl>
  </section>

  <!-- ============ 自我介紹 ============ -->
  <section class="mx-auto max-w-6xl px-5 py-12 sm:px-8">
    <span class="eyebrow">About me</span>
    <h2 class="h-section mt-3">自我介紹</h2>
    <p
      class="mt-8 max-w-4xl text-base leading-loose text-[var(--color-muted)] sm:text-lg"
    >
      {profile.intro}
    </p>
  </section>

  <!-- ============ 核心技能 ============ -->
  <section class="mx-auto max-w-6xl px-5 py-12 sm:px-8">
    <span class="eyebrow">Core skills</span>
    <h2 class="h-section mt-3">核心技能</h2>
    <ul class="mt-8 grid gap-3 sm:grid-cols-2 lg:grid-cols-3">
      {
        profile.coreSkills.map((s) => (
          <li class="flex items-start gap-3 rounded-xl border border-[var(--color-line)] bg-[var(--color-surface)] p-4 text-sm">
            <span
              class="mt-1.5 inline-block h-1.5 w-1.5 shrink-0 rounded-full"
              style="background: var(--color-accent);"
              aria-hidden="true"
            />
            <span>{s}</span>
          </li>
        ))
      }
    </ul>
  </section>

  <!-- ============ 工作經歷 ============ -->
  <section class="mx-auto max-w-6xl px-5 py-12 sm:px-8">
    <span class="eyebrow">Experience</span>
    <h2 class="h-section mt-3">工作經歷</h2>

    <div class="mt-8 space-y-10">
      {
        experience.map((job) => (
          <article class="border-l-2 border-[var(--color-line)] pl-6">
            <div class="flex flex-wrap items-baseline justify-between gap-x-6 gap-y-1">
              <h3 class="text-lg font-bold text-[var(--color-fg)]">
                {job.title}｜{job.company}
              </h3>
              <span class="text-sm text-[var(--color-muted)]">
                {job.period}
                {job.current && (
                  <span
                    class="ml-2 inline-block h-2 w-2 rounded-full align-middle"
                    style="background: var(--color-accent); box-shadow: 0 0 0 4px var(--color-accent-soft);"
                    aria-label="current"
                  />
                )}
              </span>
            </div>
            {job.summary && (
              <p class="mt-4 text-base leading-relaxed text-[var(--color-muted)]">
                {job.summary}
              </p>
            )}
          </article>
        ))
      }
    </div>
  </section>

  <!-- ============ 關鍵成果 ============ -->
  <section class="mx-auto max-w-6xl px-5 py-12 sm:px-8">
    <span class="eyebrow">Key results</span>
    <h2 class="h-section mt-3">關鍵成果</h2>

    <ul class="mt-8 space-y-3">
      {
        profile.keyResults.map((kr) => (
          <li class="flex flex-wrap items-baseline gap-x-3 gap-y-1 border-b border-[var(--color-line)] pb-3">
            <span class="text-sm text-[var(--color-subtle)]">●</span>
            <span class="font-medium text-[var(--color-fg)]">{kr.label}：</span>
            <span class="font-bold" style="color: var(--color-accent);">
              {kr.value}
            </span>
            {kr.note && (
              <span class="text-sm text-[var(--color-muted)]">（{kr.note}）</span>
            )}
          </li>
        ))
      }
    </ul>
  </section>

  <!-- ============ 工作細節 4 子節 ============ -->
  {
    subsections.map((sub) => (
      <section class="mx-auto max-w-6xl px-5 py-12 sm:px-8">
        <h3 class="text-xl font-bold text-[var(--color-fg)]">
          <span style="color: var(--color-accent);">▍</span>
          {sub.title}
        </h3>
        <ul class="mt-6 space-y-3">
          {sub.bullets.map((b) => (
            <li class="flex gap-3 text-base leading-relaxed text-[var(--color-muted)]">
              <span class="mt-2 inline-block h-1.5 w-1.5 shrink-0 rounded-full" style="background: var(--color-accent);" aria-hidden="true" />
              <span>{b}</span>
            </li>
          ))}
        </ul>
      </section>
    ))
  }

  <!-- ============ 語言能力 ============ -->
  {
    languageGroup && (
      <section class="mx-auto max-w-6xl px-5 py-12 pb-20 sm:px-8">
        <span class="eyebrow">Languages</span>
        <h2 class="h-section mt-3">語言能力</h2>
        <ul class="mt-8 grid gap-3 sm:grid-cols-2">
          {languageGroup.items.map((item) => (
            <li class="flex items-start gap-3 rounded-xl border border-[var(--color-line)] bg-[var(--color-surface)] p-4 text-sm">
              <span
                class="mt-1.5 inline-block h-1.5 w-1.5 shrink-0 rounded-full"
                style="background: var(--color-accent);"
                aria-hidden="true"
              />
              <span>{item}</span>
            </li>
          ))}
        </ul>
      </section>
    )
  }

  <script>
    import "../scripts/countup.ts";
  </script>
</BaseLayout>

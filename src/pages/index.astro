---
import BaseLayout from "../layouts/BaseLayout.astro";
import { getCollection } from "astro:content";
import WorkCard from "../components/WorkCard.astro";
import PartnerWall from "../components/PartnerWall.astro";
import profile from "../data/profile.json";

const base = import.meta.env.BASE_URL.replace(/\/$/, "");

const works = await getCollection("works");
const featured = works
  .filter((w) => w.data.featured)
  .sort((a, b) => (a.data.order ?? 99) - (b.data.order ?? 99))
  .slice(0, 3);
---

<BaseLayout>
  <!-- ============ HERO ============ -->
  <section
    class="relative mx-auto max-w-6xl px-5 pt-16 pb-24 sm:px-8 sm:pt-24 sm:pb-32"
  >
    <div
      class="pointer-events-none absolute -top-32 right-0 h-[420px] w-[420px] rounded-full opacity-30 blur-3xl"
      style="background: radial-gradient(closest-side, var(--color-accent), transparent);"
    >
    </div>

    <span class="eyebrow fade-up fade-up-1">{profile.role}</span>

    <h1 class="h-display mt-6 fade-up fade-up-2">
      嗨, 我是<span style="color: var(--color-accent);">{profile.name}</span>。<br
      />
      <span class="text-[var(--color-muted)]">把品牌講進對的人耳裡。</span>
    </h1>

    <p
      class="mt-8 max-w-2xl text-base leading-relaxed text-[var(--color-muted)] sm:text-lg fade-up fade-up-3"
    >
      {profile.tagline}
    </p>

    <div class="mt-10 flex flex-wrap items-center gap-3 fade-up fade-up-4">
      <a href={`${base}/works`} class="btn btn-primary">看作品集 →</a>
      <a href={`${base}/contact`} class="btn btn-ghost">合作邀約</a>
      {
        profile.available && (
          <span class="inline-flex items-center gap-2 rounded-full border border-[var(--color-line)] px-3 py-1.5 text-xs text-[var(--color-muted)]">
            <span
              class="h-2 w-2 rounded-full"
              style="background: var(--color-accent); box-shadow: 0 0 0 4px var(--color-accent-soft);"
            />
            {profile.availabilityNote}
          </span>
        )
      }
    </div>

    <!-- Mini stats -->
    <div class="mt-16 grid grid-cols-3 gap-4 fade-up fade-up-4 sm:gap-8">
      {
        profile.stats.map((s) => (
          <div class="rounded-2xl border border-[var(--color-line)] bg-[var(--color-surface)] p-4 sm:p-6">
            <div class="text-[10px] uppercase tracking-[0.3em] text-[var(--color-subtle)]">
              {s.label}
            </div>
            <div
              class="mt-2 font-bold leading-none"
              style="font-size: clamp(1.75rem, 4vw, 2.75rem);"
            >
              <span data-countup={s.value} style="color: var(--color-accent);">
                {s.value}
              </span>
              {s.suffix && (
                <span class="ml-1 text-sm text-[var(--color-muted)]">
                  {s.suffix}
                </span>
              )}
            </div>
          </div>
        ))
      }
    </div>
  </section>

  <!-- ============ FEATURED WORKS ============ -->
  <section class="mx-auto max-w-6xl px-5 py-20 sm:px-8">
    <div class="flex items-end justify-between gap-6">
      <div>
        <span class="eyebrow">Selected works</span>
        <h2 class="h-section mt-3">精選案例</h2>
      </div>
      <a
        href={`${base}/works`}
        class="hidden text-sm text-[var(--color-muted)] hover:text-[var(--color-accent)] md:inline"
        >看全部 →</a
      >
    </div>

    <div class="mt-10 grid gap-6 md:grid-cols-3">
      {featured.map((w) => <WorkCard entry={w} />)}
    </div>

    <div class="mt-10 text-center md:hidden">
      <a href={`${base}/works`} class="btn btn-ghost">看全部作品 →</a>
    </div>
  </section>

  <!-- ============ PARTNER WALL ============ -->
  <PartnerWall />

  <!-- ============ CTA ============ -->
  <section class="mx-auto max-w-6xl px-5 pb-24 sm:px-8">
    <div
      class="relative overflow-hidden rounded-3xl border border-[var(--color-line)] bg-[var(--color-surface)] p-8 sm:p-14"
    >
      <div
        class="pointer-events-none absolute -right-20 -top-20 h-60 w-60 rounded-full blur-3xl"
        style="background: var(--color-accent-soft);"
      >
      </div>
      <div class="relative grid items-center gap-8 md:grid-cols-[1.4fr_1fr]">
        <div>
          <span class="eyebrow">Let's work together</span>
          <h2 class="h-section mt-3">有想做的案子？我們聊聊。</h2>
          <p class="mt-4 max-w-xl text-[var(--color-muted)]">
            從品牌策略、整合行銷到單檔活動操盤都可以談。先寄一封 email 給我，告訴我品牌、預算範圍與時程，48 小時內回覆。
          </p>
        </div>
        <div class="flex flex-col gap-3 md:items-end">
          <a href={`${base}/contact`} class="btn btn-primary">寫信給我 →</a>
          <a href={`mailto:${profile.email}`} class="text-sm text-[var(--color-muted)]"
            >{profile.email}</a
          >
        </div>
      </div>
    </div>
  </section>

  <script>
    import "../scripts/countup.ts";
  </script>
</BaseLayout>

---
import BaseLayout from "../layouts/BaseLayout.astro";
import profile from "../data/profile.json";

// 若要啟用 Formspree，請到 https://formspree.io/ 取得 endpoint，並把以下字串替換成你的 form ID
// 例如 "https://formspree.io/f/abcdwxyz"
const FORMSPREE_ENDPOINT = "https://formspree.io/f/your-form-id";
---

<BaseLayout title={`聯絡 ${profile.name} | ${profile.role}`}>
  <section class="mx-auto max-w-6xl px-5 pt-16 pb-12 sm:px-8 sm:pt-24">
    <span class="eyebrow">Contact</span>
    <h1 class="h-display mt-4">合作邀約</h1>
    <p class="mt-6 max-w-2xl text-[var(--color-muted)]">
      告訴我「品牌名」、「想做什麼」、「預算與時程」三件事，我會在 48 小時內回信。也歡迎直接寄信、加 LinkedIn。
    </p>
  </section>

  <section class="mx-auto max-w-6xl px-5 pb-24 sm:px-8">
    <div class="grid gap-10 md:grid-cols-[1fr_1.4fr]">
      <!-- Info -->
      <div class="space-y-6">
        <div
          class="rounded-2xl border border-[var(--color-line)] bg-[var(--color-surface)] p-6"
        >
          <div class="text-[10px] uppercase tracking-[0.3em] text-[var(--color-subtle)]">
            Email
          </div>
          <a
            href={`mailto:${profile.email}`}
            class="mt-2 block text-lg font-medium text-[var(--color-fg)] hover:text-[var(--color-accent)]"
          >
            {profile.email}
          </a>
        </div>

        <div
          class="rounded-2xl border border-[var(--color-line)] bg-[var(--color-surface)] p-6"
        >
          <div class="text-[10px] uppercase tracking-[0.3em] text-[var(--color-subtle)]">
            Social
          </div>
          <ul class="mt-3 space-y-2">
            {
              profile.social.map((s) => (
                <li>
                  <a
                    href={s.url}
                    target="_blank"
                    rel="noreferrer"
                    class="nav-link"
                  >
                    {s.label} →
                  </a>
                </li>
              ))
            }
          </ul>
        </div>

        <div
          class="rounded-2xl border border-[var(--color-line)] bg-[var(--color-surface)] p-6"
        >
          <div class="text-[10px] uppercase tracking-[0.3em] text-[var(--color-subtle)]">
            Location
          </div>
          <div class="mt-2 font-medium">{profile.location}</div>
          <p class="mt-2 text-sm text-[var(--color-muted)]">
            可遠端配合北美 / 東南亞時區。
          </p>
        </div>
      </div>

      <!-- Form -->
      <form
        action={FORMSPREE_ENDPOINT}
        method="POST"
        class="space-y-5 rounded-2xl border border-[var(--color-line)] bg-[var(--color-surface)] p-6 sm:p-8"
      >
        <div class="grid gap-5 sm:grid-cols-2">
          <label class="block">
            <span class="text-xs uppercase tracking-[0.2em] text-[var(--color-subtle)]"
              >姓名 / Name</span
            >
            <input
              type="text"
              name="name"
              required
              class="mt-2 w-full rounded-lg border border-[var(--color-line)] bg-[var(--color-bg)] px-4 py-3 text-[var(--color-fg)] outline-none focus:border-[var(--color-accent)]"
            />
          </label>
          <label class="block">
            <span class="text-xs uppercase tracking-[0.2em] text-[var(--color-subtle)]"
              >Email</span
            >
            <input
              type="email"
              name="email"
              required
              class="mt-2 w-full rounded-lg border border-[var(--color-line)] bg-[var(--color-bg)] px-4 py-3 text-[var(--color-fg)] outline-none focus:border-[var(--color-accent)]"
            />
          </label>
        </div>

        <label class="block">
          <span class="text-xs uppercase tracking-[0.2em] text-[var(--color-subtle)]"
            >品牌 / Brand</span
          >
          <input
            type="text"
            name="brand"
            class="mt-2 w-full rounded-lg border border-[var(--color-line)] bg-[var(--color-bg)] px-4 py-3 text-[var(--color-fg)] outline-none focus:border-[var(--color-accent)]"
          />
        </label>

        <label class="block">
          <span class="text-xs uppercase tracking-[0.2em] text-[var(--color-subtle)]"
            >合作方向 / Inquiry</span
          >
          <select
            name="type"
            class="mt-2 w-full rounded-lg border border-[var(--color-line)] bg-[var(--color-bg)] px-4 py-3 text-[var(--color-fg)] outline-none focus:border-[var(--color-accent)]"
          >
            <option value="">— 請選擇 —</option>
            <option value="brand-strategy">品牌策略 / 定位</option>
            <option value="campaign">整合行銷活動</option>
            <option value="social">社群經營</option>
            <option value="kol">KOL 媒合</option>
            <option value="other">其他</option>
          </select>
        </label>

        <label class="block">
          <span class="text-xs uppercase tracking-[0.2em] text-[var(--color-subtle)]"
            >訊息 / Message</span
          >
          <textarea
            name="message"
            rows="6"
            required
            class="mt-2 w-full rounded-lg border border-[var(--color-line)] bg-[var(--color-bg)] px-4 py-3 text-[var(--color-fg)] outline-none focus:border-[var(--color-accent)]"
            placeholder="品牌、想做什麼、預算與時程"
          ></textarea>
        </label>

        <input type="hidden" name="_subject" value="Portfolio 合作邀約" />

        <button type="submit" class="btn btn-primary w-full justify-center">
          送出 →
        </button>
        <p class="text-xs text-[var(--color-subtle)]">
          表單由 Formspree 處理。要啟用前請編輯 <code>src/pages/contact.astro</code>
          ，把 <code>FORMSPREE_ENDPOINT</code> 換成你的 form ID。
        </p>
      </form>
    </div>
  </section>
</BaseLayout>
